# --- Build-time ---
# Replicate (FLUX 1.1 Pro · scripts/generate-images.ts)
REPLICATE_API_TOKEN=

# --- Runtime · booking flow (fase 2) ---

# Neon Postgres (server-side only, used by Drizzle)
# Required when PAYMENT_MODE=production OR when accepting any booking
DATABASE_URL=

# HMAC secret for IDOR token signing (kind-separated: checkout 30min / portal 90d)
# Generate with: openssl rand -hex 32
HMAC_SECRET=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM=Sur41 <reservas@sur41.example>

# MercadoPago Checkout Pro
# In simulated mode (default) MP creds are NOT required
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Payment mode: simulated (default, no real charge) | production (real MP)
PAYMENT_MODE=simulated

# Public site URL (used for MP back_urls + webhook). Vercel auto-fills via VERCEL_PROJECT_PRODUCTION_URL.
NEXT_PUBLIC_SITE_URL=
